# Exemplo de variáveis de ambiente.
# Copie para .env no desenvolvimento local e ajuste os valores reais.
PORT=3000
NODE_ENV=development

# String de conexão do Neon/PostgreSQL.
DATABASE_URL=postgresql://neondb_owner:sua_senha@ep-seu-host.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Segredo usado para assinar cookies de sessão.
SESSION_SECRET=seu_segredo_aleatorio_aqui
STORE_WHATSAPP_NUMBER=5561981624432

# Credenciais iniciais criadas pelo seed ou pela inicialização automática.
ADMIN_NAME=Administrador Manvielle
ADMIN_EMAIL=admin@manvielleelegance.com.br
ADMIN_PASSWORD=troque-esta-senha