<section class="page-hero compact-hero">
  <div class="container">
    <span class="eyebrow">Contato</span>
    <h1>Vamos desenhar seu próximo evento?</h1>
    <p>Envie uma mensagem com o estilo do evento, data prevista e itens desejados para receber um retorno personalizado.</p>
  </div>
</section>

<section class="section">
  <div class="container contact-grid">
    <form class="form-panel" action="/contato" method="POST" novalidate>
      <div class="form-group">
        <label for="name">Nome</label>
        <input id="name" name="name" type="text" value="<%= formData.name || '' %>" required>
        <% if (errors.name) { %><small class="field-error"><%= errors.name %></small><% } %>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" value="<%= formData.email || '' %>" required>
        <% if (errors.email) { %><small class="field-error"><%= errors.email %></small><% } %>
      </div>
      <div class="form-group">
        <label for="phone">Telefone</label>
        <input id="phone" name="phone" type="tel" value="<%= formData.phone || '' %>" required>
        <% if (errors.phone) { %><small class="field-error"><%= errors.phone %></small><% } %>
      </div>
      <div class="form-group">
        <label for="message">Mensagem</label>
        <textarea id="message" name="message" rows="5" required><%= formData.message || '' %></textarea>
        <% if (errors.message) { %><small class="field-error"><%= errors.message %></small><% } %>
      </div>
      <button class="btn btn-primary btn-full" type="submit">Enviar mensagem</button>
    </form>

    <aside class="contact-info">
      <span class="eyebrow">Atendimento</span>
      <h2><%= storeInfo.name %></h2>
      <p><strong>Telefone:</strong> <%= contactInfo.phone %></p>
      <p><strong>Email:</strong> <%= contactInfo.email %></p>
      <p><strong>Endereço:</strong> <%= contactInfo.address %></p>
      <div class="contact-actions">
        <a class="btn btn-primary" href="<%= contactInfo.whatsapp %>" target="_blank" rel="noreferrer">WhatsApp</a>
        <a class="btn btn-outline" href="<%= contactInfo.instagram %>" target="_blank" rel="noreferrer">Instagram</a>
      </div>
    </aside>
  </div>
</section>
