<% if (dbError) { %>
  <div class="flash-wrap is-static">
    <div class="flash flash-error"><%= dbError %></div>
  </div>
<% } %>

<section class="admin-section">
  <div class="admin-section-header">
    <div>
      <span class="eyebrow">Catálogo</span>
      <h2>Gerenciar produtos e serviços</h2>
    </div>
    <a class="btn btn-primary" href="/admin/items/new">Adicionar item</a>
  </div>

  <form class="filter-bar admin-filter" action="/admin/items" method="GET">
    <label>
      <span>Pesquisa</span>
      <input type="search" name="search" placeholder="Nome, tipo ou categoria" value="<%= filters.search %>">
    </label>
    <label>
      <span>Tipo</span>
      <select name="type">
        <option value="">Todos</option>
        <option value="Produto" <%= filters.type === 'Produto' ? 'selected' : '' %>>Produto</option>
        <option value="Serviço" <%= filters.type === 'Serviço' ? 'selected' : '' %>>Serviço</option>
      </select>
    </label>
    <button class="btn btn-primary" type="submit">Buscar</button>
    <a class="btn btn-outline" href="/admin/items">Limpar</a>
  </form>

  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Tipo</th>
          <th>Categoria</th>
          <th>Preço</th>
          <th>Status</th>
          <th>Atualização</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length) { %>
          <% items.forEach((item) => { %>
            <tr>
              <td>
                <strong><%= item.name %></strong>
                <small><%= item.description.substring(0, 72) %><%= item.description.length > 72 ? '...' : '' %></small>
              </td>
              <td><%= item.type %></td>
              <td><%= item.category %></td>
              <td><%= formatCurrency(item.price) %></td>
              <td><span class="status-badge <%= item.status === 'Ativo' ? 'is-active' : 'is-inactive' %>"><%= item.status %></span></td>
              <td><%= formatDate(item.updated_at || item.created_at) %></td>
              <td>
                <div class="table-actions">
                  <a class="btn btn-small btn-outline" href="/admin/items/<%= item.id %>/edit">Editar</a>
                  <form action="/admin/items/<%= item.id %>/delete" method="POST" data-confirm="Excluir este item?">
                    <button class="btn btn-small btn-danger" type="submit">Excluir</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="table-empty">Nenhum item encontrado.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
