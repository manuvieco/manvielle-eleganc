<% const isEdit = mode === 'edit'; %>
<% const action = isEdit ? `/admin/items/${item.id}` : '/admin/items'; %>

<section class="admin-section">
  <div class="admin-section-header">
    <div>
      <span class="eyebrow"><%= isEdit ? 'Edição' : 'Cadastro' %></span>
      <h2><%= isEdit ? 'Editar item' : 'Novo produto ou serviço' %></h2>
    </div>
    <a class="btn btn-outline" href="/admin/items">Voltar</a>
  </div>

  <% if (errors.general) { %>
    <div class="flash-wrap is-static">
      <div class="flash flash-error"><%= errors.general %></div>
    </div>
  <% } %>

  <form class="form-panel admin-form" action="<%= action %>" method="POST" novalidate>
    <div class="form-grid">
      <div class="form-group">
        <label for="name">Nome</label>
        <input id="name" name="name" type="text" value="<%= item.name || '' %>" required>
        <% if (errors.name) { %><small class="field-error"><%= errors.name %></small><% } %>
      </div>

      <div class="form-group">
        <label for="type">Tipo</label>
        <select id="type" name="type" required>
          <option value="">Selecione</option>
          <option value="Produto" <%= item.type === 'Produto' ? 'selected' : '' %>>Produto</option>
          <option value="Serviço" <%= item.type === 'Serviço' ? 'selected' : '' %>>Serviço</option>
        </select>
        <% if (errors.type) { %><small class="field-error"><%= errors.type %></small><% } %>
      </div>

      <div class="form-group">
        <label for="category">Categoria</label>
        <input id="category" name="category" type="text" value="<%= item.category || '' %>" required>
        <% if (errors.category) { %><small class="field-error"><%= errors.category %></small><% } %>
      </div>

      <div class="form-group">
        <label for="price">Preço</label>
        <input id="price" name="price" type="number" min="0" step="0.01" value="<%= item.price !== undefined && item.price !== null ? item.price : '' %>" required>
        <% if (errors.price) { %><small class="field-error"><%= errors.price %></small><% } %>
      </div>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status" required>
          <option value="">Selecione</option>
          <option value="Ativo" <%= item.status === 'Ativo' ? 'selected' : '' %>>Ativo</option>
          <option value="Inativo" <%= item.status === 'Inativo' ? 'selected' : '' %>>Inativo</option>
        </select>
        <% if (errors.status) { %><small class="field-error"><%= errors.status %></small><% } %>
      </div>

      <div class="form-group">
        <label for="image_url">Imagem opcional</label>
        <input id="image_url" name="image_url" type="url" value="<%= item.image_url || '' %>" placeholder="/images/products-real/convite-acetato.jpg">
        <% if (errors.image_url) { %><small class="field-error"><%= errors.image_url %></small><% } %>
      </div>
    </div>

    <div class="form-group">
      <label for="description">Descrição</label>
      <textarea id="description" name="description" rows="6" required><%= item.description || '' %></textarea>
      <% if (errors.description) { %><small class="field-error"><%= errors.description %></small><% } %>
    </div>

    <div class="form-actions">
      <button class="btn btn-primary" type="submit"><%= isEdit ? 'Salvar alterações' : 'Cadastrar item' %></button>
      <a class="btn btn-outline" href="/admin/items">Cancelar</a>
    </div>
  </form>
</section>